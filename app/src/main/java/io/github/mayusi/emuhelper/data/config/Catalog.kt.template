/*
 * ───────────────────────────────────────────────────────────────────────────
 *  TEMPLATE — this file is committed to the public repository.
 *
 *  To build EmuHelper you must create the real source list:
 *
 *      1. Copy this file to `Catalog.kt` in the same directory.
 *      2. Fill in the `IA_LINKS` map below with the endpoint URLs you configure
 *         for each platform key.
 *
 *  `Catalog.kt` is git-ignored on purpose so that source URLs are NOT published
 *  in the repository. Everything else (platform metadata, colours, ordering, and
 *  the helper functions) is shared here and can be used as-is.
 *
 *  Each entry maps a platform key to a list of "download endpoint" URLs that
 *  return a directory listing / metadata the scanner can read. Example shape:
 *
 *      "snes" to listOf(
 *          "https://example.org/download/<collection-id>/<path>/",
 *      ),
 * ───────────────────────────────────────────────────────────────────────────
 */
package io.github.mayusi.emuhelper.data.config

object Catalog {

    /**
     * Platform key -> list of endpoint URLs you configure for the scanner.
     *
     * LEFT EMPTY IN THE TEMPLATE. Add your own sources in your local `Catalog.kt`.
     * The app compiles and runs with empty lists; platforms simply report zero
     * sources until you populate them.
     */
    val IA_LINKS: Map<String, List<String>> = mapOf(
        "ps1" to emptyList(),
        "ps2" to emptyList(),
        "psp" to emptyList(),
        "wii" to emptyList(),
        "wiiu" to emptyList(),
        "3ds" to emptyList(),
        "ds" to emptyList(),
        "snes" to emptyList(),
        "gba" to emptyList(),
